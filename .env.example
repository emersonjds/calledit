# Point the app at the real calledit-api. Leave unset to run on MSW (mock backend, served at /api).
VITE_API_BASE_URL=https://calledit-api-production.up.railway.app/api

# Solana RPC used for on-chain SOL balance reads. Devnet by default — never hardcode mainnet in code.
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# TxLINE fixture id the live match tracks.
VITE_LIVE_MATCH_ID=18257739

# Force demo mode (MSW) even when VITE_API_BASE_URL is set.
# VITE_FORCE_DEMO=true
